{
  "name": "govtschemes",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node --env-file-if-exists=.env scripts/build-index.ts",
    "dev": "next dev",
    "prebuild": "node --env-file-if-exists=.env scripts/build-index.ts",
    "build": "next build",
    "test": "node --test lib/*.test.ts",
    "typecheck": "tsc --noEmit",
    "db:up": "docker compose up -d db",
    "db:migrate": "node --env-file-if-exists=.env scripts/migrate.ts",
    "db:seed": "node --env-file-if-exists=.env scripts/seed.ts"
  },
  "dependencies": {
    "next": "^16.2.7",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3"
  }
}
