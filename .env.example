# Copy to .env and fill in. .env is gitignored; this example file is committed.

# Local dev DB (docker-compose). In CI/production builds, point this at Neon.
DATABASE_URL=postgresql://govtschemes:govtschemes@localhost:5432/govtschemes

# Used only by the Phase 5 prose-rewriting pass. Never needed at runtime (D1).
OPENAI_API_KEY=

# Optional: Cloudflare Pages "Deploy Hook" URL. Lets the review tool's
# "Deploy live" button trigger a site rebuild. Create it in:
# Cloudflare Pages → your project → Settings → Builds & deployments → Deploy hooks.
CLOUDFLARE_DEPLOY_HOOK=
